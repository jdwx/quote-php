{
  "name": "jdwx/quote",
  "description": "A PHP module for handling complex quoted strings.",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "JDWX\\Quote\\": "src/"
    }
  },
  "require": {
    "php": ">=8.3.0",
    "ext-mbstring": "*",
    "jdwx/strict": "^1.1.1"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest",
    "jetbrains/phpstorm-attributes": "^1.0",
    "phpunit/phpunit": "^12",
    "phan/phan": "^v6",
    "phpstan/phpstan": "^2.0"
  },
  "scripts": {
    "phan": "PHAN_ALLOW_XDEBUG=1 php -d xdebug.mode=off vendor/bin/phan --no-progress-bar -S --analyze-twice",
    "phpstan": "php -d xdebug.so vendor/bin/phpstan --no-progress",
    "phpunit": "vendor/bin/phpunit tests"
  }
}
